                            "profit_30_fbo",
                            "profit_30_fbs"
                        ]
                    },
                    {
                        "name": "direction",
                        "in": "query",
                        "description": "Направление сортировки",
                        "type": "string",
                        "enum": [
                            "desc",
                            "asc"
                        ]
                    },
                    {
                        "name": "period",
                        "in": "query",
                        "description": "Период данных",
                        "type": "number",
                        "enum": [7, 14, 30]
                    },
                    {
                        "name": "fb",
                        "in": "query",
                        "description": "FBO / FBS",
                        "type": "string",
                        "enum": [
                            "fbo", 
                            "fbs"
                        ]
                    },
                    {
                        "name": "dateTo",
                        "in": "query",
                        "description": "Дата до которой нужна статистика в формате 2023-05-01, если не указана то берется последний парсинг",
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "schema": {
                            "$ref": "#/definitions/ApiResponse"
