    "definitions": {
        "ApiResponseAny": {
            "type": "object",
            "properties": {}
        },
        "ApiResponseQuery": {
            "type": "object",
            "properties": {
                "price_avg_diff": {
                    "type": "number",
                    "description": "Стабильность среднего чека - изменение среднего чека в течение месяца"
                },
                "monopoly": {
                    "type": "number",
                    "description": "Монополия - объем продаж у топ 10 продавцов по обороту в данной нише относительного общего оборота по нише"
                },
                "sales_org": {
                    "type": "number",
                    "description": "Оценка потенциала органических продаж - процент товаров с продажами от общего количества товаров"
                },
                "sales_avg": {
                    "type": "number",
                    "description": "Среднее количество продаж у товаров"
                },
                "products_count": {
                    "type": "number",
                    "description": "Конкурентный ассортимент - количество товаров в нише"
                },
                "sales_trend": {
